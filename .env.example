MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rescuenet?retryWrites=true&w=majority

# Vertex AI configuration (replaces GEMINI_API_KEY — uses Application Default Credentials)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model to use via Vertex AI
# Supported: gemini-2.0-flash, gemini-2.0-flash-001, gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-pro
GEMINI_MODEL=gemini-2.0-flash

NEXT_PUBLIC_APP_NAME=RescueNet AI
